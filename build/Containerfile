# Stage 1: Go builder — kantra and kantra release assets
FROM registry.access.redhat.com/ubi9/go-toolset AS go-builder

ARG KANTRA_VERSION=v0.9.2-rc.1
ARG KANTRA_REPO=https://github.com/konveyor/kantra.git
ARG KANTRA_BRANCH=main
ARG KANTRA_ARCH=amd64
USER root
RUN dnf install -y unzip && dnf clean all

RUN curl -fSL -o /tmp/kantra.zip \
    "https://github.com/konveyor/kantra/releases/download/${KANTRA_VERSION}/kantra.linux.${KANTRA_ARCH}.zip" \
    && mkdir -p /kantra-assets && unzip /tmp/kantra.zip -d /kantra-assets/ \
    && rm /tmp/kantra.zip

RUN git clone --depth 1 --branch "$KANTRA_BRANCH" "$KANTRA_REPO" /src/kantra
WORKDIR /src/kantra
RUN CGO_ENABLED=0 go build -o /kantra-assets/kantra main.go

RUN : > /kantra-assets/maven-index.txt \
    && rm -rf /kantra-assets/rulesets /kantra-assets/jdtls /kantra-assets/fernflower.jar \
    && mkdir -p /kantra-assets/rulesets


# Stage 2: Rust builder — semver-analyzer, frontend-analyzer-provider, fix-engine-cli
FROM registry.access.redhat.com/ubi9/ubi AS rust-builder

ARG SEMVER_REPO=https://github.com/konveyor-ecosystem/semver-analyzer.git
ARG SEMVER_BRANCH=main
ARG KONVEYOR_CORE_REPO=https://github.com/konveyor-ecosystem/konveyor-core.git
ARG KONVEYOR_CORE_BRANCH=main
ARG FAP_REPO=https://github.com/konveyor-ecosystem/frontend-analyzer-provider.git
ARG FAP_BRANCH=main
ARG FIX_ENGINE_REPO=https://github.com/konveyor-ecosystem/fix-engine.git
ARG FIX_ENGINE_BRANCH=main

RUN dnf install -y gcc gcc-c++ make openssl-devel pkg-config git && dnf clean all

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /src
RUN git clone --branch "$KONVEYOR_CORE_BRANCH" "$KONVEYOR_CORE_REPO" \
    && git clone --branch "$SEMVER_BRANCH" "$SEMVER_REPO" \
    && git clone --branch "$FAP_BRANCH" "$FAP_REPO" \
    && git clone --branch "$FIX_ENGINE_BRANCH" "$FIX_ENGINE_REPO"

WORKDIR /src/semver-analyzer
RUN cargo build --release

WORKDIR /src/frontend-analyzer-provider
RUN cargo build --release

WORKDIR /src/fix-engine
RUN cargo build --release

RUN strip \
    /src/semver-analyzer/target/release/semver-analyzer \
    /src/frontend-analyzer-provider/target/release/frontend-analyzer-provider \
    /src/fix-engine/target/release/fix-engine-cli


# ═══════════════════════════════════════════════════════════════════════════
# Stage 3a: PatternFly React rules
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS pf-rule-gen

ARG PF_REACT_REPO=https://github.com/patternfly/patternfly-react.git
ARG PF_CSS_REPO=https://github.com/patternfly/patternfly.git
ARG PF_REACT_FROM=v5.3.3
ARG PF_REACT_TO=v6.4.1
ARG PF_DEP_FROM=v5.4.0
ARG PF_DEP_TO=v6.4.0
ARG PF_FROM_NODE_VERSION=18
ARG PF_TO_NODE_VERSION=20
ARG PF_FROM_INSTALL_CMD="corepack yarn install"
ARG PF_FROM_BUILD_CMD="corepack yarn build"
ARG PF_TO_BUILD_CMD="yarn build:generate && yarn build:esm"
ARG PF_DEP_NODE_VERSION=18
ARG PF_DEP_BUILD_CMD="export NODE_ENV=development && yarn install && npx gulp buildPatternfly"
ARG TOKEN_MAPPINGS_URL=https://raw.githubusercontent.com/konveyor-ecosystem/semver-analyzer/refs/heads/main/hack/integration/patternfly-token-mappings.yaml

RUN dnf install -y git make gcc gcc-c++ && dnf clean all

SHELL ["/bin/bash", "-c"]
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$PF_FROM_NODE_VERSION" \
    && nvm install "$PF_TO_NODE_VERSION" \
    && nvm install "$PF_DEP_NODE_VERSION" \
    && nvm alias default "$PF_TO_NODE_VERSION" \
    && nvm use "$PF_FROM_NODE_VERSION" && corepack enable \
    && nvm use "$PF_TO_NODE_VERSION" && corepack enable

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

WORKDIR /src
RUN git clone "$PF_REACT_REPO" && git clone "$PF_CSS_REPO"
RUN curl -fSL -o /src/patternfly-token-mappings.yaml "$TOKEN_MAPPINGS_URL"

ENV YARN_ENABLE_SCRIPTS=false
ENV PUPPETEER_SKIP_DOWNLOAD=true
RUN source "$NVM_DIR/nvm.sh" && semver-analyzer analyze typescript \
    --repo /src/patternfly-react \
    --from "$PF_REACT_FROM" --to "$PF_REACT_TO" \
    --dep-repo /src/patternfly \
    --dep-from "$PF_DEP_FROM" --dep-to "$PF_DEP_TO" \
    --dep-build-command "$PF_DEP_BUILD_CMD" \
    --from-dep-node-version "$PF_DEP_NODE_VERSION" \
    --to-dep-node-version "$PF_DEP_NODE_VERSION" \
    --from-node-version "$PF_FROM_NODE_VERSION" \
    --to-node-version "$PF_TO_NODE_VERSION" \
    --from-install-command "$PF_FROM_INSTALL_CMD" \
    --from-build-command "$PF_FROM_BUILD_CMD" \
    --to-build-command "$PF_TO_BUILD_CMD" \
    --no-llm \
    \
    -o /src/semver_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/semver_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name patternfly-breaking-changes \
    --rename-patterns /src/patternfly-token-mappings.yaml

SHELL ["/bin/sh", "-c"]


# ═══════════════════════════════════════════════════════════════════════════
# Stage 3b: PatternFly React Topology rules
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS topology-rule-gen

ARG TOPOLOGY_REPO=https://github.com/patternfly/react-topology.git
ARG TOPOLOGY_FROM=v5.4.1
ARG TOPOLOGY_TO=v6.4.0
ARG TOPOLOGY_FROM_NODE_VERSION=20
ARG TOPOLOGY_TO_NODE_VERSION=20
ARG TOPOLOGY_FROM_INSTALL_CMD="yarn config set cache-folder /tmp/yarn-cache && rm -rf /tmp/yarn-cache && yarn install --frozen-lockfile --ignore-scripts --mutex file:/tmp/yarn-mutex --network-concurrency 1"
ARG TOPOLOGY_TO_INSTALL_CMD="yarn config set cache-folder /tmp/yarn-cache && rm -rf /tmp/yarn-cache && yarn install --frozen-lockfile --ignore-scripts --mutex file:/tmp/yarn-mutex --network-concurrency 1"
ARG TOPOLOGY_FROM_BUILD_CMD="yarn build"
ARG TOPOLOGY_TO_BUILD_CMD="yarn build"

RUN dnf install -y git make gcc gcc-c++ && dnf clean all

SHELL ["/bin/bash", "-c"]
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$TOPOLOGY_FROM_NODE_VERSION" \
    && nvm install "$TOPOLOGY_TO_NODE_VERSION" \
    && nvm alias default "$TOPOLOGY_TO_NODE_VERSION" \
    && npm install -g yarn@1.22.22

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

WORKDIR /src
RUN git clone "$TOPOLOGY_REPO"

ENV YARN_ENABLE_SCRIPTS=false
RUN source "$NVM_DIR/nvm.sh" && semver-analyzer analyze typescript \
    --repo /src/react-topology \
    --from "$TOPOLOGY_FROM" --to "$TOPOLOGY_TO" \
    --from-node-version "$TOPOLOGY_FROM_NODE_VERSION" \
    --to-node-version "$TOPOLOGY_TO_NODE_VERSION" \
    --from-install-command "$TOPOLOGY_FROM_INSTALL_CMD" \
    --to-install-command "$TOPOLOGY_TO_INSTALL_CMD" \
    --from-build-command "$TOPOLOGY_FROM_BUILD_CMD" \
    --to-build-command "$TOPOLOGY_TO_BUILD_CMD" \
    --no-llm \
    \
    -o /src/topology_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/topology_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name topology-breaking-changes

SHELL ["/bin/sh", "-c"]


