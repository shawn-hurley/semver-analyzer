# ═══════════════════════════════════════════════════════════════════════════
# Stage 3d: Dynamic Plugin SDK rules
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS sdk-rule-gen

ARG SDK_REPO=https://github.com/openshift/dynamic-plugin-sdk.git
ARG SDK_FROM_DATE=2023-04-13
ARG SDK_TO_DATE=2024-01-15
ARG SDK_FROM_NODE_VERSION=20
ARG SDK_TO_NODE_VERSION=20
ARG SDK_FROM_BUILD_CMD="yarn install && yarn build"
ARG SDK_TO_BUILD_CMD="yarn install && yarn build"

RUN dnf install -y git make gcc gcc-c++ && dnf clean all

SHELL ["/bin/bash", "-c"]
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$SDK_FROM_NODE_VERSION" \
    && nvm install "$SDK_TO_NODE_VERSION" \
    && nvm alias default "$SDK_TO_NODE_VERSION" \
    && npm install -g corepack && corepack enable

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

WORKDIR /src
RUN git clone "$SDK_REPO"

# Resolve commits from npm publish dates
RUN SDK_FROM_COMMIT=$(cd /src/dynamic-plugin-sdk && \
        git log --after="$(date -d "$SDK_FROM_DATE - 2 days" +%Y-%m-%d)" \
                --before="$(date -d "$SDK_FROM_DATE + 2 days" +%Y-%m-%d)" \
                --format="%H" -- packages/lib-core/package.json 2>/dev/null | head -1) \
    && SDK_TO_COMMIT=$(cd /src/dynamic-plugin-sdk && \
        git log --after="$(date -d "$SDK_TO_DATE - 2 days" +%Y-%m-%d)" \
                --before="$(date -d "$SDK_TO_DATE + 2 days" +%Y-%m-%d)" \
                --format="%H" -- packages/lib-core/package.json 2>/dev/null | head -1) \
    && echo "SDK_FROM_COMMIT=$SDK_FROM_COMMIT" && echo "SDK_TO_COMMIT=$SDK_TO_COMMIT" \
    && source "$NVM_DIR/nvm.sh" && semver-analyzer analyze typescript \
        --repo /src/dynamic-plugin-sdk \
        --from "$SDK_FROM_COMMIT" --to "$SDK_TO_COMMIT" \
        --from-build-command "$SDK_FROM_BUILD_CMD" \
        --to-build-command "$SDK_TO_BUILD_CMD" \
        --no-llm \
        \
        -o /src/sdk_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/sdk_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name dynamic-plugin-sdk-breaking-changes

SHELL ["/bin/sh", "-c"]


# ═══════════════════════════════════════════════════════════════════════════
# Stage 3e: Console SDK rules
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS console-rule-gen

ARG CONSOLE_REPO=https://github.com/openshift/console.git
ARG CONSOLE_FROM=origin/release-4.17
ARG CONSOLE_TO=origin/release-4.19
ARG CONSOLE_FROM_NODE_VERSION=20
ARG CONSOLE_TO_NODE_VERSION=20
ARG CONSOLE_FROM_INSTALL_CMD="cd frontend && corepack enable && YARN_ENABLE_SCRIPTS=false yarn install"
ARG CONSOLE_TO_INSTALL_CMD="cd frontend && corepack enable && YARN_ENABLE_SCRIPTS=false yarn install"
ARG CONSOLE_FROM_BUILD_CMD="cd frontend && yarn build-plugin-sdk"
ARG CONSOLE_TO_BUILD_CMD="cd frontend && yarn build-plugin-sdk"
ARG CONSOLE_SDK_FROM_VERSION=1.4.0
ARG CONSOLE_SDK_TO_VERSION=4.21.0

RUN dnf install -y git make gcc gcc-c++ && dnf clean all

SHELL ["/bin/bash", "-c"]
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$CONSOLE_FROM_NODE_VERSION" \
    && nvm install "$CONSOLE_TO_NODE_VERSION" \
    && nvm alias default "$CONSOLE_TO_NODE_VERSION" \
    && npm install -g corepack && corepack enable

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

WORKDIR /src
RUN git clone "$CONSOLE_REPO"

RUN source "$NVM_DIR/nvm.sh" && semver-analyzer analyze typescript \
    --repo /src/console \
    --from "$CONSOLE_FROM" --to "$CONSOLE_TO" \
    --from-node-version "$CONSOLE_FROM_NODE_VERSION" \
    --to-node-version "$CONSOLE_TO_NODE_VERSION" \
    --from-install-command "$CONSOLE_FROM_INSTALL_CMD" \
    --to-install-command "$CONSOLE_TO_INSTALL_CMD" \
    --from-build-command "$CONSOLE_FROM_BUILD_CMD" \
    --to-build-command "$CONSOLE_TO_BUILD_CMD" \
    --no-llm \
    \
    -o /src/console_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/console_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name console-sdk-breaking-changes \
    --package-name-map "@console/dynamic-plugin-sdk=@openshift-console/dynamic-plugin-sdk" \
    --package-version "@openshift-console/dynamic-plugin-sdk=${CONSOLE_SDK_FROM_VERSION}:${CONSOLE_SDK_TO_VERSION}"

SHELL ["/bin/sh", "-c"]


# ═══════════════════════════════════════════════════════════════════════════
# Stage 3f: React rules
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS react-rule-gen

ARG REACT_REPO=https://github.com/facebook/react.git
ARG REACT_FROM=v17.0.2
ARG REACT_TO=v18.3.1
ARG REACT_FROM_NODE_VERSION=18
ARG REACT_TO_NODE_VERSION=18
ARG REACT_FROM_BUILD_CMD="yarn build"
ARG REACT_TO_BUILD_CMD="yarn build"

RUN dnf install -y git make gcc gcc-c++ java-17-openjdk-headless && dnf clean all

SHELL ["/bin/bash", "-c"]
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$REACT_FROM_NODE_VERSION" \
    && nvm alias default "$REACT_FROM_NODE_VERSION" \
    && npm install -g yarn@1.22.22

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1

WORKDIR /src
RUN git clone --bare "$REACT_REPO" react/.git \
    && cd react && git config core.bare false && git checkout "$REACT_TO"

ARG REACT_FROM_INSTALL_CMD="yarn config set cache-folder /tmp/yarn-cache && rm -rf /tmp/yarn-cache && yarn install --ignore-scripts --ignore-optional --mutex file:/tmp/yarn-mutex --network-concurrency 1"
ARG REACT_TO_INSTALL_CMD="yarn config set cache-folder /tmp/yarn-cache && rm -rf /tmp/yarn-cache && yarn install --ignore-scripts --ignore-optional --mutex file:/tmp/yarn-mutex --network-concurrency 1"

RUN source "$NVM_DIR/nvm.sh" && semver-analyzer analyze typescript \
    --repo /src/react \
    --from "$REACT_FROM" --to "$REACT_TO" \
    --from-node-version "$REACT_FROM_NODE_VERSION" \
    --to-node-version "$REACT_TO_NODE_VERSION" \
    --from-install-command "$REACT_FROM_INSTALL_CMD" \
    --to-install-command "$REACT_TO_INSTALL_CMD" \
    --from-build-command "$REACT_FROM_BUILD_CMD" \
    --to-build-command "$REACT_TO_BUILD_CMD" \
    --no-llm \
    \
    -o /src/react_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/react_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name react-breaking-changes

SHELL ["/bin/sh", "-c"]


# ═══════════════════════════════════════════════════════════════════════════
# Stage 3g: React Types rules (synthetic repo from DefinitelyTyped)
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi AS react-types-gen

ARG DT_REPO=https://github.com/DefinitelyTyped/DefinitelyTyped.git
ARG REACT_TYPES_FROM=v17
ARG REACT_TYPES_TO=v18

RUN dnf install -y git && dnf clean all \
    && git config --global user.name "build" \
    && git config --global user.email "build@localhost"

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

WORKDIR /src

# Sparse-clone DefinitelyTyped (only types/react and types/react-dom)
RUN git clone --filter=blob:none --sparse "$DT_REPO" DefinitelyTyped \
    && cd DefinitelyTyped && git sparse-checkout set types/react types/react-dom

# Build synthetic repo with v17 and v18 tags
RUN mkdir -p react-types && cd react-types && git init -q \
    && mkdir -p packages/react packages/react-dom \
    && cp -a /src/DefinitelyTyped/types/react/v17/* packages/react/ 2>/dev/null || true \
    && rm -rf packages/react/test \
    && cp -a /src/DefinitelyTyped/types/react-dom/v17/* packages/react-dom/ 2>/dev/null || true \
    && rm -rf packages/react-dom/test \
    && find packages -name package.json -exec sed -i 's/\([0-9]\+\)\.\([0-9]\+\)\.9999/\1.\2.0/g' {} + \
    && git add -A && git commit -q -m "v17: @types/react v17" && git tag v17 \
    && rm -rf packages/react/* packages/react-dom/* \
    && cp -a /src/DefinitelyTyped/types/react/v18/* packages/react/ 2>/dev/null || true \
    && rm -rf packages/react/test packages/react/ts5.0 \
    && cp -a /src/DefinitelyTyped/types/react-dom/v18/* packages/react-dom/ 2>/dev/null || true \
    && rm -rf packages/react-dom/test packages/react-dom/ts5.0 \
    && find packages -name package.json -exec sed -i 's/\([0-9]\+\)\.\([0-9]\+\)\.9999/\1.\2.0/g' {} + \
    && git add -A && git commit -q -m "v18: @types/react v18" && git tag v18

RUN semver-analyzer analyze typescript \
    --repo /src/react-types \
    --from "$REACT_TYPES_FROM" --to "$REACT_TYPES_TO" \
    --from-install-command "true" \
    --to-install-command "true" \
    --from-build-command "true" \
    --to-build-command "true" \
    --no-llm \
    \
    -o /src/react_types_report.json

RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/react_types_report.json \
    --output-dir /rules/semver_rules \
    --ruleset-name react-types-breaking-changes


# ═══════════════════════════════════════════════════════════════════════════
# Stage 4: Runtime image
# ═══════════════════════════════════════════════════════════════════════════
FROM registry.access.redhat.com/ubi9/ubi-minimal

RUN microdnf install -y --nodocs \
    bash \
    python3 \
    python3-pyyaml \
    python3.11 \
    python3.11-pip \
    python3.11-setuptools \
    git \
    which \
    procps-ng \
    lsof \
    bzip2 \
    tar \
    libgomp \
    expect \
    gcc \
    make \
    && curl -fsSL https://www.sqlite.org/2024/sqlite-autoconf-3450300.tar.gz \
        | tar xz -C /tmp \
    && cd /tmp/sqlite-autoconf-3450300 \
    && ./configure --prefix=/usr/local && make -j$(nproc) && make install \
    && echo /usr/local/lib > /etc/ld.so.conf.d/sqlite3.conf && ldconfig \
    && rm -rf /tmp/sqlite-autoconf-3450300 \
    && microdnf remove -y gcc make \
    && microdnf clean all

RUN ln -sf /usr/bin/python3.11 /usr/local/bin/python3.11 \
    && ln -sf /usr/bin/pip3.11 /usr/local/bin/pip3.11

RUN pip3.11 install --no-cache-dir --no-warn-script-location mempalace

RUN curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - \
    && microdnf install -y --nodocs nodejs \
    && microdnf clean all \
    && corepack enable

RUN ln -sf /usr/bin/python3.11 /usr/bin/python3

ARG TARGETARCH=amd64
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${TARGETARCH}" \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

ENV CONFIGURE=false
RUN curl -fsSL \
    https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash
ENV CONFIGURE=

ENV KANTRA_DIR=/opt/patternfly-tools/.kantra
ENV PATH="/root/.local/bin:${PATH}"

RUN git config --system safe.directory '*' \
    && git config --system user.name "PatternFly Migration" \
    && git config --system user.email "pf-migration@localhost"

WORKDIR /opt/patternfly-tools

# Kantra assets
COPY --from=go-builder /kantra-assets/ .kantra/

# Rust binaries
RUN mkdir -p bin
COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer bin/
COPY --from=rust-builder /src/frontend-analyzer-provider/target/release/frontend-analyzer-provider bin/
COPY --from=rust-builder /src/fix-engine/target/release/fix-engine-cli bin/

# Rules from all 7 stages — separate subdirectory per library
COPY --from=pf-rule-gen /rules/ rules/patternfly/
COPY --from=pf-rule-gen /src/patternfly-token-mappings.yaml .
COPY --from=topology-rule-gen /rules/ rules/topology/
COPY --from=rcg-rule-gen /rules/ rules/react-component-groups/
COPY --from=sdk-rule-gen /rules/ rules/dynamic-plugin-sdk/
COPY --from=console-rule-gen /rules/ rules/console-sdk/
COPY --from=react-rule-gen /rules/ rules/react/
COPY --from=react-types-gen /rules/ rules/react-types/


# Default goose config
RUN mkdir -p /root/.config/goose
COPY goose-config.yaml /root/.config/goose/config.yaml
RUN chmod 444 /root/.config/goose/config.yaml

# run.sh and prompt
COPY run.sh eval.sh prompt.md eval_prompt.md* ./
RUN chmod +x run.sh eval.sh bin/* .kantra/kantra

